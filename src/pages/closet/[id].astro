---
import Base from "../../layouts/Base.astro";
import { closets, getItemsByCloset, conversations } from "../../data/mock";
import { withBase } from "../../lib/paths";

export function getStaticPaths() {
  return closets.map((closet) => ({
    params: { id: closet.id },
    props: { closet },
  }));
}

const { closet } = Astro.props;
const closetItems = getItemsByCloset(closet.id);
const availableCount = closetItems.filter((i) => i.available).length;
const existingConv = conversations.find((c) => c.withClosetId === closet.id);
const messageHref = existingConv
  ? withBase(`/messages?conv=${existingConv.id}`)
  : withBase("/messages");
---

<Base title={`${closet.name} — Closet Audit`}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <!-- Profile header -->
    <div class="flex flex-col items-center text-center mb-8">
      <span class="w-20 h-20 rounded-full bg-sage-light text-sage-dark flex items-center justify-center text-2xl font-display font-bold mb-4">
        {closet.avatar}
      </span>
      <h1 class="font-display font-bold text-2xl">{closet.name}</h1>
      <p class="text-sm text-muted">@{closet.handle}</p>

      <!-- Stats row -->
      <div class="flex gap-8 mt-5">
        <div class="text-center">
          <p class="font-bold text-charcoal">{closetItems.length}</p>
          <p class="text-xs text-muted">items</p>
        </div>
        <div class="text-center">
          <p class="font-bold text-charcoal">{closet.followers.toLocaleString()}</p>
          <p class="text-xs text-muted">followers</p>
        </div>
        <div class="text-center">
          <p class="font-bold text-charcoal">{availableCount}</p>
          <p class="text-xs text-muted">available</p>
        </div>
      </div>

      <!-- Bio -->
      <div class="mt-4 max-w-sm">
        <p class="text-sm text-muted">📍 {closet.location}</p>
        <p class="text-sm mt-1">{closet.bio}</p>
        {closet.venmo && (
          <p class="text-xs text-muted mt-1">💰 Venmo: @{closet.venmo}</p>
        )}
      </div>

      <div class="flex gap-2 mt-5">
        <button class="px-6 py-2 text-sm font-semibold text-white bg-sage hover:bg-sage-dark rounded-button transition-colors">
          Follow
        </button>
        <a href={messageHref} class="px-6 py-2 text-sm font-semibold text-charcoal bg-white border border-border hover:border-charcoal/20 rounded-button transition-colors">
          Message
        </a>
      </div>
    </div>

    <!-- Rental rules -->
    {closet.rules.length > 0 && (
      <div class="mb-8 p-5 rounded-card bg-warm-white border border-border">
        <h2 class="font-display font-semibold text-sm mb-3">Rental Rules</h2>
        <ul class="space-y-1.5">
          {closet.rules.map((rule) => (
            <li class="text-sm text-muted flex items-start gap-2">
              <span class="mt-0.5 text-sage font-bold">–</span>
              {rule}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Item grid (IG-style 3 column) -->
    <div class="grid grid-cols-3 gap-1 sm:gap-2">
      {closetItems.map((item) => (
        <a href={withBase(`/item/${item.id}`)} class="group relative aspect-square overflow-hidden rounded-sm bg-border/40">
          <img
            src={item.images[0]}
            alt={item.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100">
            <span class="text-white text-sm font-bold">${item.rentPrice}</span>
          </div>
          {!item.available && (
            <div class="absolute top-1 right-1">
              <span class="px-1.5 py-0.5 text-[10px] font-semibold text-white bg-black/60 rounded-pill">Rented</span>
            </div>
          )}
        </a>
      ))}
    </div>

    {closetItems.length === 0 && (
      <div class="text-center py-16 text-muted">
        <p>No items listed yet.</p>
      </div>
    )}
  </div>
</Base>
