---
import Base from "../../layouts/Base.astro";
import Avatar from "../../components/Avatar.astro";
import { closets, getItemsByCloset, conversations } from "../../data/mock";
import { withBase } from "../../lib/paths";

export function getStaticPaths() {
  return closets.map((closet) => ({
    params: { id: closet.id },
    props: { closet },
  }));
}

const { closet } = Astro.props;
const closetItems = getItemsByCloset(closet.id);
const availableCount = closetItems.filter((i) => i.available).length;
const existingConv = conversations.find((c) => c.withClosetId === closet.id);
const messageHref = existingConv
  ? withBase(`/messages?conv=${existingConv.id}`)
  : withBase("/messages");

const accent = closet.accentColor ?? "#8fae8b";
const social = closet.socialLinks ?? {};
const hasSocials = Object.values(social).some(Boolean);
---

<Base title={`${closet.name} — Closet Audit`}>
  <div class="max-w-4xl mx-auto">
    {/* ── Cover banner ── */}
    <div class="relative">
      <div class="relative h-44 sm:h-56 md:h-64 overflow-hidden">
        {closet.coverImage ? (
          <img
            src={closet.coverImage}
            alt=""
            width="1200"
            height="400"
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block"
          />
        ) : (
          <div
            class="absolute inset-0"
            style={`background:linear-gradient(135deg,${accent}33,${accent}11)`}
          />
        )}
        <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,0,0,.2),transparent)" />
      </div>

      {/* Avatar — overlaps the banner bottom */}
      <div class="absolute -bottom-12 left-1/2 -translate-x-1/2 z-10">
        <div class="rounded-full p-1 bg-cream shadow-lg">
          <Avatar src={closet.profileImage} initials={closet.avatar} size="lg" ring={false} />
        </div>
      </div>
    </div>

    {/* ── Profile info ── */}
    <div class="pt-16 pb-2 px-4 text-center">
      {closet.tagline && (
        <p class="text-xs font-medium tracking-wide uppercase mb-2" style={`color: ${accent}`}>
          {closet.tagline}
        </p>
      )}
      <h1 class="font-display font-bold text-2xl">{closet.name}</h1>
      <p class="text-sm text-muted mt-0.5">@{closet.handle}</p>

      {/* Stats */}
      <div class="flex justify-center gap-8 mt-5">
        <div class="text-center">
          <p class="font-bold text-charcoal text-lg">{closetItems.length}</p>
          <p class="text-[11px] text-muted uppercase tracking-wide">items</p>
        </div>
        <div class="w-px bg-border" />
        <div class="text-center">
          <p class="font-bold text-charcoal text-lg">{closet.followers.toLocaleString()}</p>
          <p class="text-[11px] text-muted uppercase tracking-wide">followers</p>
        </div>
        <div class="w-px bg-border" />
        <div class="text-center">
          <p class="font-bold text-charcoal text-lg">{availableCount}</p>
          <p class="text-[11px] text-muted uppercase tracking-wide">available</p>
        </div>
      </div>

      {/* Bio block */}
      <div class="mt-5 max-w-md mx-auto space-y-1.5">
        <p class="text-sm leading-relaxed">{closet.bio}</p>
        <p class="text-xs text-muted flex items-center justify-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          {closet.location}
        </p>
        {closet.venmo && (
          <p class="text-xs text-muted flex items-center justify-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            @{closet.venmo}
          </p>
        )}
      </div>

      {/* Social links */}
      {hasSocials && (
        <div class="flex items-center justify-center gap-3 mt-4">
          {social.instagram && (
            <a href={`https://instagram.com/${social.instagram}`} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-pill bg-white border border-border hover:border-charcoal/20 transition-colors">
              <svg class="w-3.5 h-3.5 text-muted group-hover:text-charcoal transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              Instagram
            </a>
          )}
          {social.tiktok && (
            <a href={`https://tiktok.com/@${social.tiktok}`} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-pill bg-white border border-border hover:border-charcoal/20 transition-colors">
              <svg class="w-3.5 h-3.5 text-muted group-hover:text-charcoal transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13.2a8.16 8.16 0 005.58 2.17V12a4.85 4.85 0 01-3.58-1.59V6.69h3.58z"/></svg>
              TikTok
            </a>
          )}
          {social.depop && (
            <a href={`https://depop.com/${social.depop}`} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-pill bg-white border border-border hover:border-charcoal/20 transition-colors">
              <svg class="w-3.5 h-3.5 text-muted group-hover:text-charcoal transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm3.248 7.2c1.608 0 2.952 1.344 2.952 2.952s-1.344 2.952-2.952 2.952h-2.4v3.696H9.6V7.2h5.648z"/></svg>
              Depop
            </a>
          )}
          {social.website && (
            <a href={`https://${social.website}`} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-pill bg-white border border-border hover:border-charcoal/20 transition-colors">
              <svg class="w-3.5 h-3.5 text-muted group-hover:text-charcoal transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.556a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L5.25 8.81" /></svg>
              {social.website}
            </a>
          )}
        </div>
      )}

      {/* Action buttons */}
      <div class="flex justify-center gap-2 mt-5">
        <button
          class="px-7 py-2.5 text-sm font-semibold text-white rounded-button transition-all hover:opacity-90 hover:shadow-md"
          style={`background-color: ${accent}`}
        >
          Follow
        </button>
        <a
          href={messageHref}
          class="px-7 py-2.5 text-sm font-semibold text-charcoal bg-white border border-border hover:border-charcoal/20 rounded-button transition-colors"
        >
          Message
        </a>
        <button
          class="p-2.5 text-muted bg-white border border-border hover:border-charcoal/20 rounded-button transition-colors"
          aria-label="Share this closet"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" />
          </svg>
        </button>
      </div>
    </div>

    {/* ── Divider ── */}
    <div class="border-t border-border mt-6 mx-4" />

    {/* ── Rental rules ── */}
    <div class="px-4">
      {closet.rules.length > 0 && (
        <details class="mt-6 group" open>
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <h2 class="font-display font-semibold text-sm">Rental Rules</h2>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>
          <ul class="mt-3 space-y-2">
            {closet.rules.map((rule) => (
              <li class="text-sm text-muted flex items-start gap-2.5">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style={`background-color: ${accent}`} />
                {rule}
              </li>
            ))}
          </ul>
        </details>
      )}
    </div>

    {/* ── Item grid ── */}
    <div class="px-4 mt-8 pb-12">
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-display font-semibold text-lg">
          Items
          <span class="text-sm font-normal text-muted ml-1.5">({closetItems.length})</span>
        </h2>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5">
        {closetItems.map((item) => (
          <a href={withBase(`/item/${item.id}`)} class="group">
            <div class="relative aspect-[3/4] rounded-card overflow-hidden bg-border/40">
              <img
                src={item.images[0]}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
              <span class="absolute top-2 right-2 px-2 py-0.5 text-xs font-bold text-white bg-black/60 backdrop-blur-sm rounded-pill">
                ${item.rentPrice}
              </span>
              {!item.available && (
                <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                  <span class="px-3 py-1 text-xs font-semibold text-white bg-black/60 rounded-pill">Rented</span>
                </div>
              )}
            </div>
            <div class="mt-2.5">
              <p class="text-sm font-semibold truncate group-hover:text-sage-dark transition-colors">
                {item.title}
              </p>
              <p class="text-xs text-muted mt-0.5">
                Size {item.size} · {item.condition}
              </p>
            </div>
          </a>
        ))}
      </div>

      {closetItems.length === 0 && (
        <div class="text-center py-16 text-muted">
          <p>No items listed yet.</p>
        </div>
      )}
    </div>
  </div>
</Base>
