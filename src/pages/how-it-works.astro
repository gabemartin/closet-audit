---
import Base from "../layouts/Base.astro";
---

<Base title="How It Works — Closet Audit">
  <div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-display font-bold text-3xl sm:text-4xl text-center">How Closet Audit works</h1>
    <p class="mt-4 text-center text-muted max-w-lg mx-auto">
      Think of it as a library card for your community's wardrobe. Here's the rundown.
    </p>

    <div class="mt-16 space-y-16">
      {[
        {
          step: "01",
          title: "Join or create a community",
          desc: "Find your sorority, dorm floor, or neighborhood on the platform. Communities are invite-based so you're only sharing with people you trust.",
          color: "sage",
        },
        {
          step: "02",
          title: "List what you're willing to share",
          desc: "Snap a few photos, pick a category, and add any notes (fits small, dry clean only, etc). Your items stay in your closet until someone requests them.",
          color: "lavender",
        },
        {
          step: "03",
          title: "Browse & request",
          desc: "See something you love? Hit request, suggest a borrow window, and wait for the owner to confirm. It's that simple.",
          color: "terracotta",
        },
        {
          step: "04",
          title: "Wear, return, repeat",
          desc: "Coordinate pickup and drop-off (or use community drop spots). After returning, both sides leave a quick rating to build trust.",
          color: "sky",
        },
      ].map((item) => (
        <div class="flex gap-6 items-start">
          <span class={`flex-shrink-0 w-12 h-12 rounded-2xl bg-${item.color}-light flex items-center justify-center font-display font-bold text-${item.color}-dark text-sm`}>
            {item.step}
          </span>
          <div>
            <h3 class="font-display font-semibold text-xl">{item.title}</h3>
            <p class="mt-2 text-muted leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-20 text-center">
      <h2 class="font-display font-bold text-2xl">Ready to share your closet?</h2>
      <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/browse"
          class="px-8 py-3.5 text-sm font-semibold text-white bg-charcoal hover:bg-charcoal/90 rounded-button transition-colors"
        >
          Start Browsing
        </a>
        <a
          href="/list"
          class="px-8 py-3.5 text-sm font-semibold text-charcoal bg-white border border-border hover:border-charcoal/20 rounded-button transition-colors"
        >
          List an Item
        </a>
      </div>
    </div>
  </div>
</Base>
