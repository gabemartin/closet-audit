---
import Base from "../layouts/Base.astro";
import { items, closets, communities } from "../data/mock";

const featured = items.filter((i) => i.available).slice(0, 4);
const topClosets = closets.slice(0, 4);
const topCommunities = communities.slice(0, 3);
---

<Base title="Closet Audit — Rent Clothes From Your Community">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sage-light/40 via-cream to-lavender-light/30"></div>
    <div class="relative max-w-6xl mx-auto px-4 pt-20 pb-24 sm:pt-28 sm:pb-32 text-center">
      <p class="inline-block px-3 py-1 text-xs font-semibold tracking-wide uppercase text-sage-dark bg-sage-light/60 rounded-pill mb-6">
        Your campus closet
      </p>
      <h1 class="font-display font-extrabold text-4xl sm:text-6xl leading-tight text-charcoal max-w-3xl mx-auto">
        Rent the look.<br />Skip the price tag.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-muted max-w-xl mx-auto leading-relaxed">
        Rent dresses, gameday fits, and going-out pieces from closets in your community. No more Instagram DMs.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/browse"
          class="w-full sm:w-auto px-8 py-3.5 text-sm font-semibold text-white bg-charcoal hover:bg-charcoal/90 rounded-button transition-colors"
        >
          Browse Rentals
        </a>
        <a
          href="/start"
          class="w-full sm:w-auto px-8 py-3.5 text-sm font-semibold text-charcoal bg-white border border-border hover:border-charcoal/20 rounded-button transition-colors"
        >
          List Your Closet
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <h2 class="font-display font-bold text-2xl sm:text-3xl text-center">Better than DMs</h2>
    <p class="mt-2 text-sm text-muted text-center max-w-md mx-auto">Everything these IG closet accounts do, but built for it.</p>
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-8">
      {[
        { icon: "👗", title: "Browse & filter", desc: "Search by occasion — formals, gameday, date party, 21st. Filter by size, price, and what's actually available." },
        { icon: "💰", title: "Rent with confidence", desc: "See prices upfront, rental rules, and reviews. No more DM back-and-forth. Venmo built in." },
        { icon: "📦", title: "Track it all", desc: "Know what's rented, what's due back, and who has your stuff. Automatic late fee reminders." },
      ].map((step) => (
        <div class="text-center px-4">
          <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sage-light/50 text-2xl mb-4">
            {step.icon}
          </span>
          <h3 class="font-display font-semibold text-lg">{step.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Just Listed -->
  <section class="bg-warm-white border-y border-border">
    <div class="max-w-6xl mx-auto px-4 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="font-display font-bold text-2xl sm:text-3xl">Just listed</h2>
          <p class="mt-1 text-sm text-muted">Fresh pieces available to rent right now</p>
        </div>
        <a href="/browse" class="text-sm font-semibold text-sage-dark hover:text-sage transition-colors">
          See all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
        {featured.map((item) => {
          const closet = closets.find((c) => c.id === item.closetId);
          return (
            <a href={`/item/${item.id}`} class="group">
              <div class="relative aspect-[3/4] rounded-card overflow-hidden bg-border/40">
                <img
                  src={item.images[0]}
                  alt={item.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <span class="absolute top-2 right-2 px-2 py-0.5 text-xs font-bold text-white bg-black/60 backdrop-blur-sm rounded-pill">
                  ${item.rentPrice}
                </span>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold truncate group-hover:text-sage-dark transition-colors">
                  {item.title}
                </p>
                <p class="text-xs text-muted mt-0.5">
                  Size {item.size} · {item.condition}
                </p>
                {closet && (
                  <p class="text-xs text-muted mt-0.5">{closet.name}</p>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Closets -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="font-display font-bold text-2xl sm:text-3xl">Popular closets</h2>
        <p class="mt-1 text-sm text-muted">The people behind the pieces</p>
      </div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {topClosets.map((c) => (
        <a href={`/closet/${c.id}`} class="block p-5 rounded-card border border-border bg-white hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 text-center">
          <span class="inline-flex w-14 h-14 rounded-full bg-sage-light text-sage-dark items-center justify-center text-lg font-display font-bold mb-3">
            {c.avatar}
          </span>
          <p class="font-semibold text-sm">{c.name}</p>
          <p class="text-xs text-muted">@{c.handle}</p>
          <p class="text-xs text-muted mt-2">📍 {c.location}</p>
          <div class="mt-3 flex justify-center gap-3 text-xs text-muted">
            <span><strong class="text-charcoal">{c.itemCount}</strong> items</span>
            <span><strong class="text-charcoal">{c.followers.toLocaleString()}</strong> followers</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-4 py-20 text-center">
      <h2 class="font-display font-bold text-2xl sm:text-3xl">Stop running your closet through Instagram</h2>
      <p class="mt-4 text-white/60 max-w-md mx-auto">
        Closet Audit gives you real listings, real availability, and real tracking — not a grid of posts and a DM inbox.
      </p>
      <a
          href="/start"
          class="inline-block mt-8 px-8 py-3.5 text-sm font-semibold bg-sage hover:bg-sage-dark rounded-button transition-colors"
      >
        Start Your Closet
      </a>
    </div>
  </section>
</Base>
