---
import Base from "../layouts/Base.astro";
import { items, communities } from "../data/mock";

const featured = items.filter((i) => i.available).slice(0, 4);
const topCommunities = communities.slice(0, 3);
---

<Base title="Closet Audit — Share & Borrow Clothes Locally">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sage-light/40 via-cream to-lavender-light/30"></div>
    <div class="relative max-w-6xl mx-auto px-4 pt-20 pb-24 sm:pt-28 sm:pb-32 text-center">
      <p class="inline-block px-3 py-1 text-xs font-semibold tracking-wide uppercase text-sage-dark bg-sage-light/60 rounded-pill mb-6">
        Your community's closet
      </p>
      <h1 class="font-display font-extrabold text-4xl sm:text-6xl leading-tight text-charcoal max-w-3xl mx-auto">
        Borrow the look.<br />Skip the checkout.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-muted max-w-xl mx-auto leading-relaxed">
        Share clothes with your sorority, dorm, or neighborhood. Less buying, more styling, zero waste.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/browse"
          class="w-full sm:w-auto px-8 py-3.5 text-sm font-semibold text-white bg-charcoal hover:bg-charcoal/90 rounded-button transition-colors"
        >
          Start Browsing
        </a>
        <a
          href="/communities"
          class="w-full sm:w-auto px-8 py-3.5 text-sm font-semibold text-charcoal bg-white border border-border hover:border-charcoal/20 rounded-button transition-colors"
        >
          Find Your Community
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <h2 class="font-display font-bold text-2xl sm:text-3xl text-center">How it works</h2>
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-8">
      {[
        { icon: "📸", title: "List it", desc: "Snap a photo, add a few details, and your piece is live for your community to browse." },
        { icon: "🤝", title: "Lend or borrow", desc: "Request an item, coordinate a pickup, and set a return date. All within your trusted circle." },
        { icon: "✨", title: "Wear & return", desc: "Rock the look, then return it. Rate the experience and build your community reputation." },
      ].map((step, i) => (
        <div class="text-center px-4">
          <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sage-light/50 text-2xl mb-4">
            {step.icon}
          </span>
          <h3 class="font-display font-semibold text-lg">{step.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Items -->
  <section class="bg-warm-white border-y border-border">
    <div class="max-w-6xl mx-auto px-4 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="font-display font-bold text-2xl sm:text-3xl">Just listed</h2>
          <p class="mt-1 text-sm text-muted">Fresh pieces from your communities</p>
        </div>
        <a href="/browse" class="text-sm font-semibold text-sage-dark hover:text-sage transition-colors">
          See all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
        {featured.map((item) => (
          <a href={`/item/${item.id}`} class="group">
            <div class="aspect-[4/5] rounded-card overflow-hidden bg-border/40">
              <img
                src={item.images[0]}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
            <div class="mt-3">
              <p class="text-sm font-semibold truncate group-hover:text-sage-dark transition-colors">
                {item.title}
              </p>
              <p class="text-xs text-muted mt-0.5">
                {item.size} · {item.condition} · {item.owner.community}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Communities -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="font-display font-bold text-2xl sm:text-3xl">Active communities</h2>
        <p class="mt-1 text-sm text-muted">Find your people, share your style</p>
      </div>
      <a href="/communities" class="text-sm font-semibold text-sage-dark hover:text-sage transition-colors">
        View all &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {topCommunities.map((c) => (
        <a
          href={`/communities/${c.id}`}
          class="block p-6 rounded-card border border-border bg-white hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
        >
          <div class="flex items-center gap-3 mb-3">
            <span class={`w-10 h-10 rounded-full bg-${c.color}-light flex items-center justify-center text-${c.color}-dark font-display font-bold text-sm`}>
              {c.name.charAt(0)}
            </span>
            <div>
              <p class="font-semibold text-sm">{c.name}</p>
              <p class="text-xs text-muted capitalize">{c.type}</p>
            </div>
          </div>
          <p class="text-sm text-muted leading-relaxed">{c.description}</p>
          <div class="mt-4 flex gap-4 text-xs text-muted">
            <span><strong class="text-charcoal">{c.memberCount}</strong> members</span>
            <span><strong class="text-charcoal">{c.activeListings}</strong> items</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-4 py-20 text-center">
      <h2 class="font-display font-bold text-2xl sm:text-3xl">Your closet is bigger than you think</h2>
      <p class="mt-4 text-white/60 max-w-md mx-auto">
        Join your community on Closet Audit and unlock hundreds of pieces — without buying a thing.
      </p>
      <a
        href="/list"
        class="inline-block mt-8 px-8 py-3.5 text-sm font-semibold bg-sage hover:bg-sage-dark rounded-button transition-colors"
      >
        List Your First Item
      </a>
    </div>
  </section>
</Base>
