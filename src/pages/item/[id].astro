---
import Base from "../../layouts/Base.astro";
import { items, getCloset } from "../../data/mock";
import { withBase } from "../../lib/paths";

export function getStaticPaths() {
  return items.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const closet = getCloset(item.closetId);
---

<Base title={`${item.title} — Closet Audit`}>
  <div class="max-w-5xl mx-auto px-4 py-10">
    <a href={withBase("/browse")} class="inline-flex items-center gap-1 text-sm text-muted hover:text-charcoal transition-colors mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Back to browse
    </a>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Image -->
      <div class="aspect-[3/4] rounded-card overflow-hidden bg-border/40">
        <img
          src={item.images[0]}
          alt={item.title}
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Details -->
      <div class="flex flex-col">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <span class="px-2.5 py-0.5 text-xs font-medium rounded-pill bg-sage-light text-sage-dark capitalize">
            {item.category}
          </span>
          {item.available ? (
            <span class="px-2.5 py-0.5 text-xs font-medium rounded-pill bg-green-100 text-green-700">Available</span>
          ) : (
            <span class="px-2.5 py-0.5 text-xs font-medium rounded-pill bg-red-50 text-red-500">Currently Rented</span>
          )}
        </div>

        <h1 class="font-display font-bold text-2xl sm:text-3xl">{item.title}</h1>

        <!-- Price -->
        <div class="mt-4 flex items-baseline gap-3">
          <span class="text-2xl font-bold text-charcoal">${item.rentPrice}</span>
          <span class="text-sm text-muted">to rent</span>
          {item.buyPrice && (
            <span class="text-sm text-muted ml-2">
              · <strong class="text-charcoal">${item.buyPrice}</strong> to buy
            </span>
          )}
        </div>

        <p class="mt-4 text-muted leading-relaxed">{item.description}</p>

        <div class="mt-6 grid grid-cols-3 gap-3">
          <div class="p-3 rounded-xl bg-warm-white border border-border text-center">
            <p class="text-xs text-muted">Size</p>
            <p class="font-semibold mt-0.5">{item.size}</p>
            {item.fitNote && <p class="text-[10px] text-muted mt-0.5">{item.fitNote}</p>}
          </div>
          <div class="p-3 rounded-xl bg-warm-white border border-border text-center">
            <p class="text-xs text-muted">Color</p>
            <p class="font-semibold mt-0.5 text-sm">{item.color}</p>
          </div>
          <div class="p-3 rounded-xl bg-warm-white border border-border text-center">
            <p class="text-xs text-muted">Condition</p>
            <p class="font-semibold mt-0.5 capitalize">{item.condition}</p>
          </div>
        </div>

        <!-- Occasion tags -->
        <div class="mt-4 flex flex-wrap gap-1.5">
          {item.occasion.map((occ) => (
            <span class="px-2.5 py-1 text-xs rounded-pill bg-lavender-light/60 text-lavender font-medium capitalize">{occ}</span>
          ))}
        </div>

        <!-- Closet owner -->
        {closet && (
          <a href={withBase(`/closet/${closet.id}`)} class="mt-8 p-4 rounded-card border border-border bg-white flex items-center gap-3 hover:shadow-sm transition-shadow">
            <span class="w-10 h-10 rounded-full bg-sage-light text-sage-dark flex items-center justify-center text-sm font-bold">
              {closet.avatar}
            </span>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold">{closet.name}</p>
              <p class="text-xs text-muted truncate">@{closet.handle} · {closet.location}</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        )}

        <!-- Rental rules preview -->
        {closet && closet.rules.length > 0 && (
          <div class="mt-4 p-4 rounded-card bg-warm-white border border-border">
            <p class="text-xs font-semibold text-charcoal mb-2">Rental Rules</p>
            <ul class="space-y-1">
              {closet.rules.slice(0, 3).map((rule) => (
                <li class="text-xs text-muted flex items-start gap-1.5">
                  <span class="mt-0.5 text-sage">•</span>
                  {rule}
                </li>
              ))}
              {closet.rules.length > 3 && (
                <li class="text-xs text-sage-dark font-medium">
                  +{closet.rules.length - 3} more — <a href={withBase(`/closet/${closet.id}`)} class="underline">view all</a>
                </li>
              )}
            </ul>
          </div>
        )}

        <div class="mt-auto pt-8">
          {item.available ? (
            <button class="w-full py-3.5 text-sm font-semibold text-white bg-sage hover:bg-sage-dark rounded-button transition-colors">
              Request to Rent — ${item.rentPrice}
            </button>
          ) : (
            <button class="w-full py-3.5 text-sm font-semibold text-muted bg-border/60 rounded-button cursor-not-allowed" disabled>
              Currently Rented
            </button>
          )}
        </div>
      </div>
    </div>
  </div>
</Base>
