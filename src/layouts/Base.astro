---
import "../styles/global.css";
import { withBase } from "../lib/paths";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Closet Audit",
  description = "Rent clothes from closets in your community",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf7f2" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Closet Audit" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="manifest" href={withBase("/manifest.webmanifest")} />
    <link rel="apple-touch-icon" href={withBase("/favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <nav
      class="sticky z-50 bg-cream/80 backdrop-blur-md border-b border-border"
      style="top: 0; padding-top: var(--safe-area-top);"
      data-mobile-nav-root
    >
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href={withBase("/")} class="flex items-center gap-2 group">
          <span class="w-8 h-8 rounded-full bg-sage flex items-center justify-center text-white font-display font-bold text-sm">
            CA
          </span>
          <span class="font-display font-bold text-lg text-charcoal group-hover:text-sage-dark transition-colors">
            Closet Audit
          </span>
        </a>

        <div class="hidden sm:flex items-center gap-6 text-sm font-medium">
          <a href={withBase("/browse")} class="text-muted hover:text-charcoal transition-colors">Browse</a>
          <a href={withBase("/closets")} class="text-muted hover:text-charcoal transition-colors">Closets</a>
          <a href={withBase("/how-it-works")} class="text-muted hover:text-charcoal transition-colors">How It Works</a>
        </div>

        <div class="flex items-center gap-3">
          <button
            type="button"
            class="sm:hidden w-9 h-9 rounded-full flex items-center justify-center text-muted hover:text-charcoal hover:bg-sage-light/30 transition-colors"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
            aria-controls="mobile-nav-menu"
            data-mobile-nav-toggle
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
              data-mobile-nav-icon-open
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
            </svg>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
              data-mobile-nav-icon-close
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
            </svg>
          </button>
          <a
            href={withBase("/messages")}
            class="relative w-9 h-9 rounded-full flex items-center justify-center text-muted hover:text-charcoal hover:bg-sage-light/30 transition-colors"
            aria-label="Messages"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            <span class="absolute -top-0.5 -right-0.5 w-4 h-4 rounded-full bg-terracotta text-white text-[9px] font-bold flex items-center justify-center">
              3
            </span>
          </a>
          <a
            href={withBase("/list")}
            class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-white bg-sage hover:bg-sage-dark rounded-button transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            List Item
          </a>
          <button
            class="w-9 h-9 rounded-full bg-lavender-light text-lavender flex items-center justify-center text-sm font-bold hover:ring-2 hover:ring-lavender/40 transition"
            aria-label="Profile"
          >
            G
          </button>
        </div>
      </div>
      <div id="mobile-nav-menu" class="sm:hidden hidden border-t border-border px-4 py-3 bg-cream/95" data-mobile-nav-menu>
        <div class="flex flex-col gap-3 text-sm font-medium">
          <a href={withBase("/browse")} class="text-muted hover:text-charcoal transition-colors" data-mobile-nav-link>Browse</a>
          <a href={withBase("/closets")} class="text-muted hover:text-charcoal transition-colors" data-mobile-nav-link>Closets</a>
          <a href={withBase("/how-it-works")} class="text-muted hover:text-charcoal transition-colors" data-mobile-nav-link>How It Works</a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border bg-warm-white">
      <div class="max-w-6xl mx-auto px-4 py-10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
          <div>
            <p class="font-display font-bold text-charcoal">Closet Audit</p>
            <p class="text-sm text-muted mt-1">Rent the look. Skip the price tag.</p>
          </div>
          <div class="flex gap-6 text-sm text-muted">
            <a href={withBase("/browse")} class="hover:text-charcoal transition-colors">Browse</a>
            <a href={withBase("/closets")} class="hover:text-charcoal transition-colors">Closets</a>
            <a href={withBase("/how-it-works")} class="hover:text-charcoal transition-colors">How It Works</a>
          </div>
        </div>
        <p class="mt-8 text-xs text-muted/60">&copy; {new Date().getFullYear()} Closet Audit. Built for communities that share.</p>
      </div>
    </footer>
    <script>
      const MOBILE_BREAKPOINT = 640;
      const navRoot = document.querySelector("[data-mobile-nav-root]");
      const navToggle = document.querySelector("[data-mobile-nav-toggle]");
      const navMenu = document.querySelector("[data-mobile-nav-menu]");
      const navOpenIcon = document.querySelector("[data-mobile-nav-icon-open]");
      const navCloseIcon = document.querySelector("[data-mobile-nav-icon-close]");
      const navLinks = document.querySelectorAll("[data-mobile-nav-link]");

      if (
        navRoot instanceof HTMLElement &&
        navToggle instanceof HTMLButtonElement &&
        navMenu instanceof HTMLElement &&
        navOpenIcon instanceof SVGElement &&
        navCloseIcon instanceof SVGElement
      ) {
        const setMenuState = (isOpen: boolean) => {
          navToggle.setAttribute("aria-expanded", String(isOpen));
          navMenu.classList.toggle("hidden", !isOpen);
          navOpenIcon.classList.toggle("hidden", isOpen);
          navCloseIcon.classList.toggle("hidden", !isOpen);
        };

        const isMenuOpen = () => navToggle.getAttribute("aria-expanded") === "true";
        const closeMenu = () => setMenuState(false);

        navToggle.addEventListener("click", () => {
          setMenuState(!isMenuOpen());
        });

        navLinks.forEach((link) => {
          if (link instanceof HTMLAnchorElement) {
            link.addEventListener("click", closeMenu);
          }
        });

        document.addEventListener("click", (event) => {
          if (!isMenuOpen()) {
            return;
          }

          if (event.target instanceof Node && !navRoot.contains(event.target)) {
            closeMenu();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && isMenuOpen()) {
            closeMenu();
          }
        });

        window.addEventListener("resize", () => {
          if (window.innerWidth >= MOBILE_BREAKPOINT && isMenuOpen()) {
            closeMenu();
          }
        });
      }
    </script>
  </body>
</html>
